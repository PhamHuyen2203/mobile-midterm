<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvRoleTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="HOME"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/welcome_prefix"
        android:textColor="@color/text_label_color"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvSessionInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnBrowseProducts"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/brand_primary"
        android:text="@string/action_browse_products"
        android:textColor="@color/white"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAdminManageOrders"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/admin_orders_title"
        android:textStyle="bold"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAdminRevenueReport"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/revenue_report_title"
        android:textStyle="bold"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAdminTopSelling"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/top_selling_title"
        android:textStyle="bold"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAdminCustomerSpending"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/customer_spending_title"
        android:textStyle="bold"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnViewCart"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/cart_title"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnMyProfile"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/profile_title"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_marginTop="32dp"
        android:text="@string/action_logout"
        android:textStyle="bold" />

</LinearLayout>